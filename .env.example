# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=YOUR_SECURE_RANDOM_SECRET_KEY_MIN_32_CHARS

# NOWPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=true

# Paykassa
PAYKASSA_MERCHANT_ID=
PAYKASSA_MERCHANT_PASSWORD=

# SMTP Config
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
